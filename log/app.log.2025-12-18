2025-12-18 17:57:59,947 - DEBUG - 127.0.0.1 - dashboard_mapper.py:19 - --- [DEBUG] DashboardMapper.get_summary called with job_ids: None
2025-12-18 17:57:59,947 - DEBUG - 127.0.0.1 - dashboard_mapper.py:21 - --- [DEBUG] Generated SQL Query:

            SELECT
                h.job_id,
                m.cd_nm,
                m.item6 as frequency,
                MIN(h.start_dt) AS min_con_dt,
                MAX(h.start_dt) AS max_con_dt,
                COUNT(*) as total_count,
                -- Overall counts
                COUNT(CASE WHEN h.status = 'CD901' THEN 1 END) as overall_success_count,
                COUNT(CASE WHEN h.status = 'CD902' THEN 1 END) as overall_ing_count,
                COUNT(CASE WHEN h.status = 'CD903' THEN 1 END) as overall_fail_count,
                COUNT(CASE WHEN h.status = 'CD904' THEN 1 END) as overall_cd904_count,
                COUNT(CASE WHEN h.status = 'CD905' THEN 1 END) as overall_no_data_count,

                -- Daily counts (today in KST)
                COUNT(CASE WHEN h.status = 'CD901' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date = CURRENT_DATE THEN 1 END) as day_success,
                COUNT(CASE WHEN h.status = 'CD902' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date = CURRENT_DATE THEN 1 END) as day_ing_count,
                COUNT(CASE WHEN h.status = 'CD903' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date = CURRENT_DATE THEN 1 END) as day_fail_count,
                COUNT(CASE WHEN h.status = 'CD905' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date = CURRENT_DATE THEN 1 END) as day_no_data_count,

                -- Weekly counts (this week in KST)
                COUNT(CASE WHEN h.status = 'CD901' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('week', CURRENT_DATE) THEN 1 END) as week_success,
                COUNT(CASE WHEN h.status = 'CD902' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('week', CURRENT_DATE) THEN 1 END) as week_ing_count,
                COUNT(CASE WHEN h.status = 'CD903' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('week', CURRENT_DATE) THEN 1 END) as week_fail_count,
                COUNT(CASE WHEN h.status = 'CD905' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('week', CURRENT_DATE) THEN 1 END) as week_no_data_count,

                -- Monthly counts (this month in KST)
                COUNT(CASE WHEN h.status = 'CD901' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('month', CURRENT_DATE) THEN 1 END) as month_success,
                COUNT(CASE WHEN h.status = 'CD902' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('month', CURRENT_DATE) THEN 1 END) as month_ing_count,
                COUNT(CASE WHEN h.status = 'CD903' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('month', CURRENT_DATE) THEN 1 END) as month_fail_count,
                COUNT(CASE WHEN h.status = 'CD905' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('month', CURRENT_DATE) THEN 1 END) as month_no_data_count,

                -- Half-year counts (last 6 months in KST)
                COUNT(CASE WHEN h.status = 'CD901' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('month', CURRENT_DATE) - INTERVAL '5 months' THEN 1 END) as half_success,
                COUNT(CASE WHEN h.status = 'CD902' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('month', CURRENT_DATE) - INTERVAL '5 months' THEN 1 END) as half_ing_count,
                COUNT(CASE WHEN h.status = 'CD903' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('month', CURRENT_DATE) - INTERVAL '5 months' THEN 1 END) as half_fail_count,
                COUNT(CASE WHEN h.status = 'CD905' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('month', CURRENT_DATE) - INTERVAL '5 months' THEN 1 END) as half_no_data_count,

                -- Yearly counts (this year in KST)
                COUNT(CASE WHEN h.status = 'CD901' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('year', CURRENT_DATE) THEN 1 END) as year_success,
                COUNT(CASE WHEN h.status = 'CD902' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('year', CURRENT_DATE) THEN 1 END) as year_ing_count,
                COUNT(CASE WHEN h.status = 'CD903' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('year', CURRENT_DATE) THEN 1 END) as year_fail_count,
                COUNT(CASE WHEN h.status = 'CD905' AND (h.start_dt::timestamp AT TIME ZONE 'Asia/Seoul')::date >= date_trunc('year', CURRENT_DATE) THEN 1 END) as year_no_data_count,

                -- 연속 실패 계산 (최근 10번 실행 중 실패 횟수)
                COALESCE((
                    SELECT COUNT(*)
                    FROM (
                        SELECT status
                        FROM TB_CON_HIST h2
                        WHERE h2.job_id = h.job_id
                        ORDER BY h2.start_dt DESC
                        LIMIT 10
                    ) recent_runs
                    WHERE recent_runs.status IN ('CD902', 'CD903') -- 실패 상태들
                ), 0) as fail_streak
            FROM
                TB_CON_HIST h
            LEFT JOIN
                TB_CON_MST m ON h.job_id = m.cd
         GROUP BY h.job_id, m.cd_nm, m.item6 ORDER BY h.job_id ASC
